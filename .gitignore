# OS
.DS_Store
Thumbs.db

# Claude Code local state
.claude/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment
.env
.env.local

# Logs
*.log

# Screenshots
*.png

# SQLite database — rebuilt from evals/results/ JSON via migration
data/dreamteam.db
data/dreamteam.db-shm
data/dreamteam.db-wal

# Eval results — rebuilt on each run
evals/results/raw/
evals/results/2026-*.json

# Draft eval files — auto-generated from sessions, not curated
evals/**/drafts/draft-*.md

# Draft dry-run sidecar files (runtime staleness detection)
evals/**/drafts/.dryrun-*

# Draft dry-run temp scenario files
evals/**/scenario-_draft-temp-*.md

# Recordings — session artifacts
recordings/*.cast
recordings/*.cast.state

# Reports — generated HTML
reports/retros/*.html

# Temp dir (eval side-effects, scratch files)
.tmp/

# Git worktrees — created by worktree-create.ts for concurrent /team sessions
.worktrees/

# Node
node_modules/
package-lock.json
